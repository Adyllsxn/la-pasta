<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LaPDF</title>
    <link rel="shortcut icon" href="~/logo.svg" type="image/x-icon">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LaPDF.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
</head>
<body>

    <!-- ===== HEADER ===== -->
    <header class="header-dark">
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <!-- Logo -->
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <img src="~/logo.svg" alt="LaPDF" height="40" class="logo-white" />
                </a>

                <!-- Botão Mobile -->
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" 
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Menu -->
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")" 
                               asp-controller="Home" asp-action="Index">Início</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Pdf" && ViewContext.RouteData.Values["action"]?.ToString() == "Compress" ? "active" : "")" 
                               asp-controller="Pdf" asp-action="Compress">Comprimir PDF</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Pdf" && ViewContext.RouteData.Values["action"]?.ToString() == "Merge" ? "active" : "")" 
                               asp-controller="Pdf" asp-action="Merge">Mesclar PDF</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Pdf" && ViewContext.RouteData.Values["action"]?.ToString() == "Split" ? "active" : "")" 
                               asp-controller="Pdf" asp-action="Split">Split PDF</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Pdf" && ViewContext.RouteData.Values["action"]?.ToString() == "Convert" ? "active" : "")" 
                               asp-controller="Pdf" asp-action="Convert">Converter PDF</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- ===== CONTEÚDO PRINCIPAL ===== -->
    <main>
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="footer-dark">
        <div class="container text-center">
            <p>&copy; 2026 LaPDF - Seu Editor de PDF. Todos os direitos reservados.</p>
        </div>
    </footer>

    <!-- ===== SCRIPTS ===== -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>